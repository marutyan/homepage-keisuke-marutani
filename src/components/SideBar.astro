---
import { Icon } from "astro-icon/components";
import KeisukeConfig from "../../keisuke.config";
import I18nKeys from "../locales/keys";
import { i18n } from "../locales/translation";
import LanguageToggle from "./LanguageToggle.svelte";
---

<div class="sidebar-inner">
  <!-- Profile -->
  <div class="flex flex-col items-center">
    <div class="avatar-ring">
      <div class="avatar-wrapper">
        <img
          src={KeisukeConfig.avatarUrl}
          alt="avatar"
          class="avatar select-none"
        />
      </div>
    </div>
    <h1 class="username mt-5">{KeisukeConfig.username}</h1>
    <p class="slogan mt-2">{KeisukeConfig.sign}</p>
  </div>

  <!-- Social Icons -->
  {
    KeisukeConfig.socialLinks.length > 0 && (
      <div class="mt-5 flex flex-row items-center justify-center gap-4">
        {KeisukeConfig.socialLinks.map((item) => (
          <a href={item.link} target="_blank" rel="noopener noreferrer" class="social-link">
            <Icon name={item.icon} size={28} />
          </a>
        ))}
      </div>
    )
  }

  <!-- Separator -->
  <hr class="separator" />

  <!-- Navigation -->
  <nav class="sidebar-nav">
    {
      KeisukeConfig.navigators.map((nav) => (
        <a href={nav.href} class="nav-item" target={nav.href.startsWith('http') ? '_blank' : undefined} rel={nav.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
          {nav.icon && <Icon name={nav.icon} size={22} class="nav-icon" />}
          <span data-i18n-key={nav.nameKey}>{i18n(nav.nameKey)}</span>
        </a>
      ))
    }
  </nav>

  <!-- Separator -->
  <hr class="separator" />

  <!-- Theme & Language toggles -->
  <div class="flex flex-row items-center justify-center gap-3">
    <button type="button" id="sidebar-theme-switcher" class="theme-btn">
      <Icon
        id="sidebar-theme-icon-light"
        name="line-md:moon-alt-to-sunny-outline-loop-transition"
        size={22}
        class="hidden"
      />
      <Icon
        id="sidebar-theme-icon-dark"
        name="line-md:sunny-outline-to-moon-alt-loop-transition"
        size={22}
        class="hidden"
      />
    </button>
    <LanguageToggle client:load />
  </div>
</div>

<style>
  .sidebar-inner {
    @apply flex h-full flex-col items-center justify-center;
  }

  .avatar-ring {
    @apply flex items-center justify-center rounded-full p-2;
    background: linear-gradient(135deg, oklch(92% 0.01 var(--hue)), oklch(96% 0.005 var(--hue)));
    box-shadow: 0 4px 20px oklch(50% 0.02 var(--hue) / 15%);
  }

  :root.dark .avatar-ring {
    background: linear-gradient(135deg, oklch(30% 0.02 var(--hue)), oklch(25% 0.015 var(--hue)));
    box-shadow: 0 4px 20px oklch(10% 0.02 var(--hue) / 30%);
  }

  .avatar-wrapper {
    @apply aspect-square w-40 overflow-hidden rounded-full;
  }

  .avatar {
    @apply h-full w-full object-cover;
  }

  .username {
    @apply text-center text-2xl font-bold text-[var(--text-color)];
    font-family: var(--brand-font);
    letter-spacing: 0.02em;
  }

  .slogan {
    @apply text-center text-sm text-[var(--text-color-lighten)];
    font-family: var(--primary-font);
  }

  .social-link {
    @apply flex items-center justify-center text-[var(--text-color)] transition-all;
    @apply hover:text-[var(--primary-color)] hover:scale-110;
  }

  .separator {
    @apply my-5 w-full border-[var(--text-color-lighten)] opacity-15;
  }

  .sidebar-nav {
    @apply flex w-full flex-col gap-1 px-2;
  }

  .nav-item {
    @apply flex flex-row items-center gap-3 rounded-lg px-4 py-3 text-[var(--text-color)] transition-all;
    @apply hover:bg-[var(--primary-color-hover)] hover:text-[var(--primary-color)];
    font-family: var(--primary-font);
    font-weight: 500;
    font-size: 1.05rem;
  }

  .nav-icon {
    @apply shrink-0;
  }

  .theme-btn {
    @apply flex h-10 w-10 items-center justify-center rounded-lg text-[var(--text-color)] transition-all;
    @apply hover:bg-[var(--primary-color-hover)] hover:text-[var(--primary-color)];
  }
</style>

<script>
  // Sidebar theme switcher (desktop)
  const reinitializeIcon = (icon: SVGElement) => {
    const cloned = icon.cloneNode(true) as SVGElement;
    icon.parentNode?.replaceChild(cloned, icon);
    return cloned;
  };

  const sidebarThemeSwitcher = document.getElementById("sidebar-theme-switcher") as HTMLButtonElement;
  let sidebarThemeIconLight = document.getElementById("sidebar-theme-icon-light") as any as SVGElement;
  let sidebarThemeIconDark = document.getElementById("sidebar-theme-icon-dark") as any as SVGElement;

  const setSidebarTheme = (theme: string) => {
    document.documentElement.setAttribute("data-theme", theme);
    localStorage.setItem("theme", theme);
    document.documentElement.classList.toggle("dark", theme === "dark");

    if (sidebarThemeIconDark) sidebarThemeIconDark.style.display = theme === "dark" ? "block" : "none";
    if (sidebarThemeIconLight) sidebarThemeIconLight.style.display = theme === "light" ? "block" : "none";

    if (theme === "dark" && sidebarThemeIconDark) sidebarThemeIconDark = reinitializeIcon(sidebarThemeIconDark);
    else if (sidebarThemeIconLight) sidebarThemeIconLight = reinitializeIcon(sidebarThemeIconLight);
  };

  if (sidebarThemeSwitcher) {
    let currentTheme = localStorage.getItem("theme") || "light";
    sidebarThemeSwitcher.addEventListener("click", () => {
      currentTheme = currentTheme === "light" ? "dark" : "light";
      setSidebarTheme(currentTheme);
    });

    document.addEventListener("DOMContentLoaded", () => {
      setSidebarTheme(currentTheme);
    });
  }
</script>
