---
import KeisukeConfig from "../../keisuke.config";
import { i18n } from "../locales/translation";
import { Icon } from "astro-icon/components";
import LanguageToggle from "./LanguageToggle.svelte";

const navCount = KeisukeConfig.navigators.length;
---

<!-- Mobile-only navbar -->
<nav class="nav" id="nav">
  <div class="relative flex h-[3.5rem] w-full items-center justify-between px-1">
    <button
      id="menu-switcher"
      type="button"
      class="flex h-10 w-10 items-center justify-center rounded-lg text-[var(--text-color)] transition-all hover:bg-[var(--primary-color-hover)] hover:text-[var(--primary-color)]"
    >
      <Icon
        id="menu-icon-closed"
        size={24}
        name="line-md:close-to-menu-transition"
        class="hidden"
      />
      <Icon
        id="menu-icon-opened"
        size={24}
        name="line-md:menu-to-close-transition"
        class="hidden"
      />
    </button>
    <a class="text-xl font-medium text-[var(--primary-color)]" href="/" style="font-family: var(--brand-font);">
      {KeisukeConfig.brandTitle}
    </a>
    <div class="flex items-center gap-1">
      <button type="button" id="theme-switcher" class="flex h-10 w-10 items-center justify-center rounded-lg text-[var(--text-color)] transition-all hover:bg-[var(--primary-color-hover)] hover:text-[var(--primary-color)]">
        <Icon
          id="theme-icon-light"
          name="line-md:moon-alt-to-sunny-outline-loop-transition"
          size={20}
          class="hidden"
        />
        <Icon
          id="theme-icon-dark"
          name="line-md:sunny-outline-to-moon-alt-loop-transition"
          size={20}
          class="hidden"
        />
      </button>
      <LanguageToggle client:load />
    </div>
  </div>

  <!-- Mobile dropdown menu -->
  <div id="mobile-menu" class="px-3">
    <ul
      id="mobile-menu-nav"
      class="mobile-menu-nav mobile-menu-nav-closed flex flex-col space-y-4 overflow-hidden text-lg font-medium text-[var(--text-color)] transition-all duration-300"
    >
      {
        KeisukeConfig.navigators.map((nav) => (
          <li>
            <a href={nav.href} class="mobile-nav-item flex items-center justify-between py-1">
              <span data-i18n-key={nav.nameKey}>{i18n(nav.nameKey)}</span>
              <Icon name="cuida:caret-right-outline" class="text-[var(--text-color-lighten)]" />
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<style define:vars={{ navCount }}>
  .nav {
    @apply fixed left-0 top-0 z-10 w-full select-none bg-[var(--card-color-transparent)] px-2 backdrop-blur-md transition-all;
    animation: 300ms nav-onload-animation;
    animation-fill-mode: forwards;
    opacity: 0;
  }

  .mobile-menu-nav-closed {
    @apply h-0 opacity-0;
  }

  .mobile-menu-nav-opened {
    @apply pb-4 opacity-100;
    height: calc(var(--navCount) * 44px + 16px);
  }

  .mobile-menu-nav li a {
    font-family: var(--primary-font);
  }

  @keyframes nav-onload-animation {
    0% { opacity: 0; transform: translateY(-3rem); }
    100% { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  const reinitializeIcon = (icon: SVGElement) => {
    const cloned = icon.cloneNode(true) as SVGElement;
    icon.parentNode?.replaceChild(cloned, icon);
    return cloned;
  };

  // Mobile menu toggle
  const menuSwitcher = document.getElementById("menu-switcher") as HTMLButtonElement;
  const mobileMenuNav = document.getElementById("mobile-menu-nav") as HTMLUListElement;
  const mobileMenuNavItems = document.getElementsByClassName("mobile-nav-item");
  let menuIconClosed = document.getElementById("menu-icon-closed") as any as SVGElement;
  let menuIconOpened = document.getElementById("menu-icon-opened") as any as SVGElement;

  let isMenuOpen = false;

  const switchMenuState = () => {
    menuIconClosed.style.display = isMenuOpen ? "block" : "none";
    menuIconOpened.style.display = !isMenuOpen ? "block" : "none";
    if (isMenuOpen) menuIconClosed = reinitializeIcon(menuIconClosed);
    else menuIconOpened = reinitializeIcon(menuIconOpened);
    if (isMenuOpen) {
      mobileMenuNav.classList.replace("mobile-menu-nav-opened", "mobile-menu-nav-closed");
    } else {
      mobileMenuNav.classList.replace("mobile-menu-nav-closed", "mobile-menu-nav-opened");
    }
    isMenuOpen = !isMenuOpen;
  };

  if (menuSwitcher) {
    menuSwitcher.addEventListener("click", switchMenuState);
    for (let i = 0; i < mobileMenuNavItems.length; ++i) {
      mobileMenuNavItems.item(i)?.addEventListener("click", switchMenuState);
    }
    document.addEventListener("click", (event) => {
      if (!menuSwitcher.contains(event.target as any) && !mobileMenuNav.contains(event.target as any) && isMenuOpen) {
        switchMenuState();
      }
    });
  }

  // Theme switcher (mobile)
  const themeSwitcher = document.getElementById("theme-switcher") as HTMLButtonElement;
  let themeIconLight = document.getElementById("theme-icon-light") as any as SVGElement;
  let themeIconDark = document.getElementById("theme-icon-dark") as any as SVGElement;
  let currentTheme = localStorage.getItem("theme") || "light";

  const setTheme = (theme: string) => {
    document.documentElement.setAttribute("data-theme", theme);
    localStorage.setItem("theme", theme);
    currentTheme = theme;
    document.documentElement.classList.toggle("dark", theme === "dark");

    if (themeIconDark) themeIconDark.style.display = theme === "dark" ? "block" : "none";
    if (themeIconLight) themeIconLight.style.display = theme === "light" ? "block" : "none";

    if (theme === "dark" && themeIconDark) themeIconDark = reinitializeIcon(themeIconDark);
    else if (themeIconLight) themeIconLight = reinitializeIcon(themeIconLight);
  };

  if (themeSwitcher) {
    themeSwitcher.addEventListener("click", () => {
      setTheme(currentTheme === "light" ? "dark" : "light");
    });
  }

  document.addEventListener("DOMContentLoaded", () => {
    setTheme(currentTheme);
    if (menuIconClosed) menuIconClosed.style.display = "block";
  });

  // Hide nav on scroll down, show on scroll up
  const navBarElement = document.getElementById("nav");
  let lastYPos = 0;
  window.addEventListener("scroll", () => {
    if (window.scrollY > 60 && window.scrollY > lastYPos) {
      if (navBarElement) navBarElement.style.transform = "translateY(-100%)";
    } else {
      if (navBarElement) navBarElement.style.transform = "translateY(0)";
    }
    lastYPos = window.scrollY;
  });
</script>
