---
import Base from "./BaseLayout.astro";
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
import SideBar from "../components/SideBar.astro";
---

<Base>
  <!-- Mobile nav (hidden on desktop) -->
  <div class="lg:hidden">
    <NavBar />
  </div>

  <div class="site-wrapper">
    <!-- Sticky sidebar (hidden on mobile, shown on desktop) -->
    <aside class="sidebar-column">
      <SideBar />
    </aside>

    <!-- Scrollable right content -->
    <div class="content-column">
      <main class="content-area onload-animation">
        <slot />
      </main>
      <Footer />
    </div>
  </div>
</Base>

<style>
  .site-wrapper {
    @apply mx-auto flex w-full max-w-6xl flex-col px-0;
    @apply lg:flex-row lg:px-6;
    min-height: 100vh;
  }

  .sidebar-column {
    @apply hidden;
    @apply lg:sticky lg:top-0 lg:block lg:h-screen lg:w-[320px] lg:shrink-0 lg:overflow-y-auto lg:py-8 lg:pr-6;
  }

  .content-column {
    @apply w-full min-w-0 pt-20;
    @apply lg:flex-1 lg:py-8;
  }

  .content-area {
    @apply space-y-6;
  }
</style>
