---
import Base from "./BaseLayout.astro";
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
import SideBar from "../components/SideBar.astro";
---

<Base>
  <!-- Mobile nav (hidden on desktop) -->
  <div class="lg:hidden">
    <NavBar />
  </div>

  <div class="site-wrapper">
    <!-- Sticky sidebar (hidden on mobile, shown on desktop) -->
    <aside class="sidebar-column">
      <SideBar />
    </aside>

    <!-- Scrollable right content -->
    <div class="content-column">
      <main class="content-area onload-animation">
        <slot />
      </main>
      <Footer />
    </div>
  </div>
</Base>

<style>
  .site-wrapper {
    @apply flex w-full flex-col;
    @apply lg:flex-row;
    min-height: 100vh;
  }

  .sidebar-column {
    @apply hidden;
    @apply lg:fixed lg:left-0 lg:top-0 lg:flex lg:h-screen lg:w-[280px] lg:items-center lg:justify-center lg:overflow-y-auto lg:py-6;
  }

  .content-column {
    @apply w-full min-w-0 pt-20;
    @apply lg:ml-[280px] lg:flex-1 lg:py-8;
  }

  .content-area {
    @apply mx-auto max-w-4xl space-y-6 lg:px-8;
  }
</style>
